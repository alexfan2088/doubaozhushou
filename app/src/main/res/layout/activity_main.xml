<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/text"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@drawable/status_background"
            android:text="正在检查设备…"
            android:textColor="@color/text"
            android:textSize="24sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/startButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="28dp"
            android:text="启动连接服务"
            android:textSize="20sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="音频连接方式"
            android:textColor="@color/text"
            android:textSize="20sp"
            android:textStyle="bold" />

        <CheckBox
            android:id="@+id/usbEnabledCheck"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:checked="true"
            android:text="启用 Type-C（优先）"
            android:textSize="18sp" />

        <CheckBox
            android:id="@+id/bluetoothEnabledCheck"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="启用蓝牙通话设备"
            android:textSize="18sp" />

        <Button
            android:id="@+id/selectBluetoothButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="选择蓝牙设备"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/selectedBluetoothText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="尚未选择蓝牙设备"
            android:textColor="@color/muted"
            android:textSize="16sp" />

        <Button
            android:id="@+id/openBluetoothSettingsButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:text="打开系统蓝牙设置"
            android:textSize="17sp" />

        <Button
            android:id="@+id/testDoubaoButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="12dp"
            android:text="测试启动豆包"
            android:textSize="20sp" />

        <Button
            android:id="@+id/accessibilityButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="12dp"
            android:text="开启连续对话自动操作"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/detailText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:textColor="@color/muted"
            android:textSize="16sp" />

    </LinearLayout>
</ScrollView>
