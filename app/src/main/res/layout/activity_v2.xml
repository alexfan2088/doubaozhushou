<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F9FC"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="16dp"
        android:paddingTop="88dp"
        android:paddingRight="16dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="豆包API"
                android:textColor="@color/text"
                android:textSize="23sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/v2TokenSettingsButton"
                android:layout_width="68dp"
                android:layout_height="38dp"
                android:backgroundTint="@color/primary"
                android:text="设置"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="原生端到端实时语音 · 不再启动豆包 App"
            android:textColor="@color/muted"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/status_background"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="当前状态"
                android:textColor="@color/primary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/v2StatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="尚未连接"
                android:textColor="@color/text"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/v2DetailText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="连接 Type-C 或蓝牙设备后自动开始实时语音。"
                android:textColor="@color/muted"
                android:textSize="12sp" />
        </LinearLayout>

        <Button
            android:id="@+id/v2SelectBluetoothButton"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginTop="6dp"
            android:backgroundTint="@color/primary"
            android:text="选择蓝牙设备"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/v2SelectedBluetoothText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="center"
            android:text="尚未选择蓝牙设备"
            android:textColor="@color/muted"
            android:textSize="11sp" />

        <CheckBox
            android:id="@+id/v2LocalWakeCheck"
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:layout_marginTop="2dp"
            android:buttonTint="@color/primary"
            android:checked="false"
            android:text="本地唤醒（豆包豆包）"
            android:textColor="@color/text"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/v2LastWakeText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="0dp"
            android:text="最近唤醒：暂无"
            android:textColor="@color/muted"
            android:textSize="12sp" />

        <Button
            android:id="@+id/v2InstallWakeModelButton"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:backgroundTint="@color/primary"
            android:text="安装本地唤醒模型"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/settings_background"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="用量统计"
                android:textColor="@color/text"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/v2UsageTable"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="vertical" />
        </LinearLayout>

        <Button
            android:id="@+id/v2StopButton"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginTop="6dp"
            android:enabled="false"
            android:text="暂停语音会话"
            android:textAllCaps="false" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/switchToV1Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:backgroundTint="@color/success"
                android:text="豆包APP"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/switchToV3Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="6dp"
                android:layout_weight="1"
                android:backgroundTint="@color/success"
                android:text="DeepSeek API"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
