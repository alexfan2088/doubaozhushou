<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F9FC"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="20dp"
        android:paddingTop="92dp"
        android:paddingRight="20dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="豆包助手 V2"
            android:textColor="@color/text"
            android:textSize="25sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="原生端到端实时语音 · 不再启动豆包 App"
            android:textColor="@color/muted"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/status_background"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="V2 会话状态"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/v2StatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="尚未连接"
                android:textColor="@color/text"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/v2DetailText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="连接 Type-C 或蓝牙设备后自动开始实时语音。"
                android:textColor="@color/muted"
                android:textSize="12sp" />
        </LinearLayout>

        <Button
            android:id="@+id/v2SelectBluetoothButton"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/primary"
            android:text="选择蓝牙设备"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/v2SelectedBluetoothText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="尚未选择蓝牙设备"
            android:textColor="@color/muted"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/settings_background"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="用量统计"
                android:textColor="@color/text"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/v2TotalTokensText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="本月累计：0 Token · 0.0 分钟"
                android:textColor="@color/text"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/v2TodayTokensText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="今日累计：0 Token · 0.0 分钟"
                android:textColor="@color/text"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/v2SessionTokensText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="本轮对话：0 Token · 0.0 分钟"
                android:textColor="@color/text"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/v2EstimatedCostText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="估算金额：未配置单价"
                android:textColor="@color/muted"
                android:textSize="12sp" />
        </LinearLayout>

        <EditText
            android:id="@+id/v2WelcomeInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/settings_background"
            android:hint="欢迎词"
            android:inputType="text"
            android:maxLines="1"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:text="樊哥，我准备好了哈"
            android:textColor="@color/text"
            android:textSize="13sp" />

        <Button
            android:id="@+id/v2StopButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:enabled="false"
            android:text="暂停语音会话"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/switchToV1Button"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="16dp"
            android:backgroundTint="@color/success"
            android:text="切换到旧版 V1"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="测试版凭证仅用于 P0 真机联调"
            android:textColor="@color/muted"
            android:textSize="11sp" />
    </LinearLayout>
</ScrollView>
