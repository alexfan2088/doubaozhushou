<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F9FC"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="16dp"
        android:paddingTop="72dp"
        android:paddingRight="16dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="豆包助手 V3"
                android:textColor="@color/text"
                android:textSize="24sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/v3SettingsButton"
                android:layout_width="88dp"
                android:layout_height="44dp"
                android:text="设置"
                android:textAllCaps="false" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DeepSeek 手机本地模型 · 下载后完全离线"
            android:textColor="@color/muted"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/status_background"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="当前状态"
                android:textColor="@color/primary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/v3StatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="正在检查本地模型"
                android:textColor="@color/text"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/v3DetailText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:textColor="@color/muted"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/v3SelectedBluetoothText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="尚未选择蓝牙设备"
            android:textSize="12sp" />

        <Button
            android:id="@+id/v3SelectBluetoothButton"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="@color/primary"
            android:text="选择蓝牙设备"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/v3RouteText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="正在检查音频设备"
            android:textColor="@color/text"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/v3ModelText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/settings_background"
            android:minHeight="110dp"
            android:padding="10dp"
            android:text="正在检查本地模型"
            android:textColor="@color/text"
            android:textSize="13sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/v3PauseButton"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="10dp"
            android:enabled="false"
            android:text="暂停语音会话"
            android:textAllCaps="false" />

        <RadioGroup
            android:id="@+id/v3TtsEngineGroup"
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/v3SystemTtsRadio"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="手机系统 TTS"
                android:textSize="12sp" />

            <RadioButton
                android:id="@+id/v3LocalTtsRadio"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="免费本地 TTS"
                android:textSize="12sp" />
        </RadioGroup>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/v3SwitchToV1Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:backgroundTint="@color/success"
                android:text="V1 豆包版"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/v3SwitchToV2Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="6dp"
                android:layout_weight="1"
                android:backgroundTint="@color/success"
                android:text="V2 大模型版"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
